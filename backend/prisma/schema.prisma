// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Defines the database connection. We're using MySQL.
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// --- ENUM Definitions ---
// It's a good practice in Prisma to define ENUMs separately.

enum UserRiskAppetite {
  low
  moderate
  high
}

enum ProductInvestmentType {
  bond
  fd
  mf
  etf
  other
}

enum ProductRiskLevel {
  low
  moderate
  high
}

enum InvestmentStatus {
  active
  matured
  cancelled
}

enum HttpMethod {
  GET
  POST
  PUT
  DELETE
}


// --- Model Definitions ---

// Maps to the 'users' table
model User {
  id            String           @id @default(uuid())
  firstName     String           @map("first_name")
  lastName      String?          @map("last_name")
  email         String           @unique
  passwordHash  String           @map("password_hash")
  balance       Decimal          @default(100000.00) @db.Decimal(15, 2)
  riskAppetite  UserRiskAppetite @default(moderate) @map("risk_appetite")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  investments      Investment[]
  transactionLogs  TransactionLog[]

  @@map("users")
}

// Maps to the 'investment_products' table
model InvestmentProduct {
  id              String                @id @default(uuid())
  name            String
  investmentType  ProductInvestmentType @map("investment_type")
  tenureMonths    Int                   @map("tenure_months")
  annualYield     Decimal               @map("annual_yield") @db.Decimal(5, 2)
  riskLevel       ProductRiskLevel      @map("risk_level")
  minInvestment   Decimal               @default(1000.00) @map("min_investment") @db.Decimal(12, 2)
  maxInvestment   Decimal?              @map("max_investment") @db.Decimal(12, 2)
  description     String?               @db.Text
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")

  investments Investment[]

  @@map("investment_products")
}

// Maps to the 'investments' table
model Investment {
  id              String           @id @default(uuid())
  userId          String           @map("user_id")
  productId       String           @map("product_id")
  amount          Decimal          @db.Decimal(12, 2)
  investedAt      DateTime         @default(now()) @map("invested_at")
  status          InvestmentStatus @default(active)
  expectedReturn  Decimal?         @map("expected_return") @db.Decimal(12, 2)
  maturityDate    DateTime?        @map("maturity_date") @db.Date

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  product InvestmentProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("investments")
}

// Maps to the 'transaction_logs' table
model TransactionLog {
  id            BigInt     @id @default(autoincrement())
  userId        String?    @map("user_id")
  email         String?
  endpoint      String
  httpMethod    HttpMethod @map("http_method")
  statusCode    Int        @map("status_code")
  errorMessage  String?    @map("error_message") @db.Text
  createdAt     DateTime   @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("transaction_logs")
}